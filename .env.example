PLOT_X_OFFSET = 450

# Define constant values
WIDTH = 1980
HEIGHT = 1080
NODE_RADIUS = 10
RENDER_EVERY = 5

# Autonomia maxima do carro (distancia em pixels). Use None para desativar.
CAR_AUTONOMY = 7000.0

# Habilitar o uso da matriz de assimetria
ATSP_ENABLED = True
ASYMMETRY_FACTOR = 0.3
ASYMMETRY_SEED = 42

# Nome dos arquivos onde ficam guardadas as posicoes das cidades
# e a matriz de assimetria
ASYMMETRIC_COSTS_FILE = "cities_asynmetric_cost_matrix.txt"
CITIES_LOCATION_FILE = "cities_locations.txt"

# Define criacao de cidades
#   True indica que as cidades serao geradas aleatoriamente
#   False indica que as cidades virao de arquivo texto pre definido
GERAR_CIDADES = False

# Total de cidades que serao geradas (somente se GERAR_CIDADES = True)
NUMBER_OF_CITIES = 20

# Total de geracoes
MAX_GENERATION_ALLOWED = 5000

# Populacao inicial
ONLY_RANDOM_POPULATION = False
RANDOM_POPULATION_PERCENT = 0.9
GENERATE_POPULATION_USING_NEAREST_NEIGHBOURS = False
GENERATE_POPULATION_USING_GREEDY_APPROACH = False
GENERATE_POPULATION_USING_CONVEX_HULL = True

# Tamanho da populacao
POPULATION_SIZE = 100

# Mutacao
MUTATION_PROBABILITY = 0.5
INCREASE_MUTATION_PROBABILITY_IF_STAGNATION = True
STAGNATION_GENERATIONS = 50
MUTATION_PROBABILITY_MAX = 0.9
MUTATION_PROBABILITY_STEP = 0.05
JUST_SWAP = True

# --- VRP: Capacidade de Carga e Multiplos Veiculos ---
NUM_VEHICLES = 1
VEHICLE_CAPACITY_WEIGHT_KG = 500.0
VEHICLE_CAPACITY_VOLUME_M3 = 10.0
DEMAND_WEIGHT_MIN = 1.0
DEMAND_WEIGHT_MAX = 50.0
DEMAND_VOLUME_MIN = 0.01
DEMAND_VOLUME_MAX = 2.0
CITIES_DEMAND_FILE = "cities_demand.csv"

# --- Configuracoes do LLM (Assistente IA) ---
# Chave de API da OpenAI (obrigatoria para funcionalidades de IA)
OPENAI_API_KEY=sua-chave-aqui
# Modelo LLM a ser utilizado (opcional, padrao: gpt-4)
LLM_MODEL=gpt-4
